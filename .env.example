# =============================================
# 3D 围棋 · 气之进化 — 环境变量配置模板
# =============================================
# 复制此文件为 .env 并填入真实的 API Key
# cp .env.example .env
#
# ⚠️ 注意: .env 已在 .gitignore 中，不会被提交到 Git

# ─── LLM AI 棋手配置（可选） ──────────────────
# 至少需要配置 2 个 agent（黑方 + 白方）
# 若不配置，系统将自动回退到本地 AI 模式

# 黑方棋手
AI_AGENT_1_KEY=your-api-key-here
AI_AGENT_1_BASE_URL=https://api.deepseek.com/v1
AI_AGENT_1_MODEL=deepseek-chat
AI_AGENT_1_NAME=黑龙
AI_AGENT_1_STYLE=均衡流
AI_AGENT_1_DESC=擅长均衡流风格的下法

# 白方棋手
AI_AGENT_2_KEY=your-api-key-here
AI_AGENT_2_BASE_URL=https://api.deepseek.com/v1
AI_AGENT_2_MODEL=deepseek-chat
AI_AGENT_2_NAME=白凤
AI_AGENT_2_STYLE=力战派
AI_AGENT_2_DESC=擅长力战派风格的下法

# ─── AI 棋评配置（可选，不填则复用 Agent 1） ──
AI_COMMENTARY_KEY=
AI_COMMENTARY_BASE_URL=https://api.deepseek.com/v1
AI_COMMENTARY_MODEL=deepseek-chat

# ─── 支持的棋风列表 ──────────────────────────
# 古风稳重 / 宇宙流 / 实地派 / 力战派 / 均衡流
